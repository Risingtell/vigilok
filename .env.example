# ===== OKX SA API (from web3.okx.com dev portal — API key / secret / passphrase) =====
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
# Optional: alternate OKX API host (e.g. a pass-through relay when your network
# can't reach web3.okx.com). Leave empty in production.
OKX_BASE_URL=

# ===== Seller (VigilOK treasury — receives all payments) =====
PAY_TO=0x...
# Signs MPP session vouchers; MUST be the private key of PAY_TO
MPP_MERCHANT_PRIVATE_KEY=0x...

# ===== MPP =====
# Any high-entropy string; signs 402 challenges
MPP_SECRET_KEY=
# OKX default escrow on X Layer (SDK default — do not change unless OKX rotates it)
MPP_ESCROW=0x5E550002e64FaF79B41D89fE8439eEb1be66CE3b

# ===== Chain =====
XLAYER_RPC=https://rpc.xlayer.tech

# ===== Buyer agents (patron demo — REAL USD₮0 on X Layer mainnet) =====
BUYER_PRIVATE_KEY=0x...

# ===== Server =====
PORT=4100
